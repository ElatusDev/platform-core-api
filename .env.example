# =============================================================================
# .env.example — Required environment variables for AkademiaPlus Platform
#
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# =============================================================================

# ─── Spring Profile ──────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=dev

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE=multi_tenant_db
DB_USER=dev
DB_PASSWORD=changeme
SPRING_DATASOURCE_USERNAME=dev
SPRING_DATASOURCE_PASSWORD=changeme
SPRING_DATASOURCE_URL=jdbc:mariadb://multi_tenant_db:3306/multi_tenant_db

# ─── JWT Signing Key ────────────────────────────────────────────────────────
# The dev entrypoint auto-generates a PKCS12 keystore on first run.
# For local profile, point to a pre-generated keystore.
KEYSTORE_PATH=/app/jwt-keystore.p12
KEYSTORE_PASS=changeme
STORE_ALIAS=platform-core-api
JWT_KEYSTORE_PATH=/app/jwt-keystore.p12
JWT_KEYSTORE_PASS=changeme
JWT_KEY_ALIAS=platform-core-api
JWT_KEYSTORE_PASSWORD=changeme
JWT_STORE_ALIAS=platform-core-api

# ─── Field-Level Encryption ─────────────────────────────────────────────────
# AES-256-GCM key (base64-encoded, 32 bytes).
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=REPLACE_WITH_BASE64_KEY

# ─── MercadoPago (Payment Gateway) ──────────────────────────────────────────
MP_ACCESS_TOKEN=REPLACE_WITH_MP_TOKEN
